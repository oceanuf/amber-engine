{
  "version": "1.0.0",
  "name": "信息比率优化器配置",
  "description": "V1.7.0 '智库并网'专项行动 - 专项三配置",
  "lookback_period": 90,
  "ir_calculation": {
    "min_data_points": 20,
    "annualization_factor": 252,
    "benchmark": "000300.SH",
    "rolling_window": 20,
    "confidence_level": 0.95,
    "adjust_for_autocorrelation": true
  },
  "weight_optimization": {
    "method": "ir_weighted",
    "min_weight": 0.01,
    "max_weight": 0.30,
    "target_ir": 0.5,
    "decay_factor": 0.95,
    "momentum_factor": 0.3,
    "diversification_penalty": 0.1,
    "turnover_constraint": 0.2
  },
  "factor_denoising": {
    "enabled": true,
    "methods": ["moving_average", "exponential_smoothing"],
    "variance_threshold": 0.8,
    "noise_ratio_threshold": 0.3,
    "smoothing_window": 5,
    "kalman_filter": {
      "enabled": false,
      "process_variance": 1e-5,
      "measurement_variance": 0.001
    }
  },
  "feedback_loop": {
    "update_frequency": "weekly",
    "rebalancing_threshold": 0.1,
    "performance_monitoring": true,
    "backtest_periods": [30, 90, 180],
    "validation_method": "walk_forward"
  },
  "algorithm_selection": {
    "min_ir": 0.1,
    "min_data_points": 30,
    "max_drawdown": -0.20,
    "win_rate": 0.55,
    "sharpe_ratio": 0.5,
    "correlation_threshold": 0.7
  },
  "reporting": {
    "generate_reports": true,
    "report_directory": "reports/ir_optimization",
    "include_charts": true,
    "performance_attribution": true,
    "risk_decomposition": true
  },
  "execution": {
    "dry_run": true,
    "confirm_changes": true,
    "rollout_strategy": "gradual",
    "max_daily_weight_change": 0.05,
    "fallback_to_previous": true
  },
  "metadata": {
    "created_date": "2026-04-05",
    "created_by": "工程师 Cheese 🧀",
    "mission": "V1.7.0 '智库并网'专项行动 - 专项三",
    "references": ["微信文章: 算法因子去噪与IR优化", "金融工程: 信息比率理论与实践"],
