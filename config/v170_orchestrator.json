{
  "version": "1.0.0",
  "name": "V1.7.0 '智库并网'专项行动调度器配置",
  "description": "统一调度三个专项任务的执行",
  "mission_control": {
    "专项一": {
      "name": "每日简报看板",
      "script": "scripts/briefing/daily_briefing.py",
      "schedule": "18:00",
      "enabled": true,
      "args": ["--mock-llm"],
      "timeout": 600,
      "retry_attempts": 3,
      "notify_on_completion": true,
      "output_directory": "reports/daily_briefing"
    },
    "专项二": {
      "name": "盘中监控点火",
      "script": "scripts/arena/intra_day_monitor.py",
      "schedule": "15min",
      "enabled": true,
      "args": ["--daemon"],
      "timeout": 300,
      "market_hours_only": true,
      "start_delay": 30,
      "monitoring": {
        "alert_channels": ["log", "file"],
        "max_alerts_per_hour": 10,
        "cooldown_period": 300
      },
      "integration": {
        "stop_profit_hook": "scripts/arena/intra_day_stop_profit.py",
        "arena_engine": true,
        "tushare_mins": true
      }
    },
    "专项三": {
      "name": "算法骨架重构",
      "script": "scripts/synthesizer/ir_optimizer.py",
      "schedule": "weekly",
      "enabled": true,
      "args": ["--lookback", "90", "--method", "ir_weighted", "--denoise"],
      "timeout": 1800,
      "day_of_week": "monday",
      "time_of_day": "02:00",
      "output": {
        "weights_file": "config/strategy_weights.json",
        "report_directory": "reports/ir_optimization",
        "update_existing": true
      }
    }
  },
  "monitoring": {
    "health_check_interval": 300,
    "status_update_interval": 60,
    "alert_on_failure": true,
    "max_consecutive_failures": 3,
    "failure_notification": {
      "enabled": true,
      "channels": ["log", "file"],
      "escalation_after": 3
    },
    "performance_tracking": {
      "enabled": true,
      "metrics": ["execution_time", "success_rate", "resource_usage"],
      "retention_days": 30
    }
  },
  "integration": {
    "existing_orchestrator": true,
    "integration_mode": "parallel",
    "notify_on_completion": true,
    "generate_reports": true,
    "log_to_central": true,
    "fallback_mechanism": {
      "enabled": true,
      "fallback_to_v141": true,
      "health_check_timeout": 30
    }
  },
  "execution_environment": {
    "python_path": "python3",
    "working_directory": ".",
    "environment_variables": {
      "TUSHARE_TOKEN": "${TUSHARE_TOKEN}",
      "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
      "TIMEZONE": "Asia/Shanghai"
    },
    "resource_limits": {
      "max_memory_mb": 1024,
      "max_cpu_percent": 80,
      "max_execution_time": 3600
    }
  },
  "logging": {
    "level": "INFO",
    "directory": "logs/v170_orchestrator",
    "max_file_size_mb": 10,
    "retention_days": 7,
    "format": "detailed",
    "rotate_daily": true
  },
  "security": {
    "validate_scripts": true,
    "sandbox_execution": false,
    "allowed_paths": [
      "scripts/",
      "config/",
      "database/",
      "reports/",
      "logs/"
    ],
    "execution_timeout": 3600
  },
  "metadata": {
    "created_date": "2026-04-05",
    "created_by": "工程师 Cheese 🧀",
    "mission": "V1.7.0 '智库并网'专项行动",
    "reference_docs": [
      "专项一需求: 每日简报看板自动化",
      "专项二需求: 盘中监控点火",
      "专项三需求: 算法骨架重构",
      "架构师训诫: 2026-04-05"
    ],
    "implementation_status": "开发完成",
    "last_updated": "2026-04-05T17:00:00+08:00",
    "next_review_date": "2026-04-12"
  }
}