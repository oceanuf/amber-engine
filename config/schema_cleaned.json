{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cleaned ETF Data Schema",
  "description": "验证清洗后的 ETF 数据 JSON 结构",
  "type": "object",
  "required": [
    "cleaned_time",
    "cleaned_by"
  ],
  "definitions": {
    "etf_history_item": {
      "type": "object",
      "required": ["date", "price", "change"],
      "properties": {
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "标准化日期格式 YYYY-MM-DD"
        },
        "price": {
          "type": "string",
          "pattern": "^\\d+\\.\\d{3,4}$",
          "description": "标准化价格，小数点后三到四位"
        },
        "change": {
          "type": "string",
          "pattern": "^[+-]\\d+\\.\\d{2}%$",
          "description": "涨跌幅，格式如 +1.23%"
        }
      },
      "additionalProperties": false
    },
    "single_etf": {
      "type": "object",
      "required": ["ticker", "name", "nav_history"],
      "properties": {
        "ticker": {
          "type": "string",
          "pattern": "^[0-9]{6}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "index_name": {
          "type": "string",
          "minLength": 1
        },
        "nav_history": {
          "type": "array",
          "items": { "$ref": "#/definitions/etf_history_item" },
          "minItems": 1
        },
        "current_nav": {
          "type": "string",
          "pattern": "^\\d+\\.\\d{3,4}$"
        },
        "daily_change": {
          "type": "string",
          "pattern": "^[+-]\\d+\\.\\d{2}%$"
        },
        "ytd_return": {
          "type": "string",
          "pattern": "^[+-]\\d+\\.\\d{2}%$"
        },
        "volume": {
          "type": "string"
        },
        "risk_level": {
          "type": "string",
          "enum": ["低", "中", "高"]
        },
        "asset_class": {
          "type": "string",
          "enum": ["股票", "债券", "商品", "货币", "混合"]
        },
        "fetch_time": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
        },
        "last_updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
        },
        "cleaned_time": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$",
          "description": "数据清洗时间戳"
        },
        "cleaned_by": {
          "type": "string",
          "description": "清洗模块名称"
        }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["etfs"],
      "properties": {
        "etfs": {
          "type": "array",
          "items": { "$ref": "#/definitions/single_etf" },
          "minItems": 1
        },
        "fetch_time": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
        },
        "data_source": {
          "type": "string"
        },
        "etf_count": {
          "type": "integer",
          "minimum": 1
        },
        "cleaned_time": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
        },
        "cleaned_by": {
          "type": "string"
        },
        "cleaned_count": {
          "type": "integer",
          "minimum": 0
        },
        "failed_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    {
      "$ref": "#/definitions/single_etf"
    }
  ]
}