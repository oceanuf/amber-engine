{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ETF Technical Analysis Schema",
  "description": "验证 ETF 技术分析指标输出的 JSON 结构",
  "type": "object",
  "required": [
    "ticker",
    "name",
    "analysis_time",
    "indicators",
    "last_updated",
    "source_module"
  ],
  "properties": {
    "ticker": {
      "type": "string",
      "pattern": "^[0-9]{6}$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "analysis_time": {
      "type": "string",
      "format": "date-time",
      "description": "分析执行时间 (ISO 8601)"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "数据最后更新时间 (ISO 8601)"
    },
    "source_module": {
      "type": "string",
      "pattern": "^analyzer_[a-z_]+$"
    },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "date",
          "price",
          "change",
          "ma5",
          "ma20",
          "ma60",
          "bias_20",
          "roc_5"
        ],
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "description": "标准化日期格式 YYYY-MM-DD"
          },
          "price": {
            "type": "number",
            "description": "当日价格 (浮点数)"
          },
          "change": {
            "type": "number",
            "description": "涨跌幅百分比 (浮点数，如 1.23 表示 1.23%)"
          },
          "ma5": {
            "anyOf": [
              {"type": "number"},
              {"type": "null"}
            ],
            "description": "5日移动平均线，数据不足时为null"
          },
          "ma20": {
            "anyOf": [
              {"type": "number"},
              {"type": "null"}
            ],
            "description": "20日移动平均线，数据不足时为null"
          },
          "ma60": {
            "anyOf": [
              {"type": "number"},
              {"type": "null"}
            ],
            "description": "60日移动平均线，数据不足时为null"
          },
          "bias_20": {
            "anyOf": [
              {"type": "number"},
              {"type": "null"}
            ],
            "description": "乖离率 (现价与20日均线的偏离百分比)"
          },
          "roc_5": {
            "anyOf": [
              {"type": "number"},
              {"type": "null"}
            ],
            "description": "5日变化率 (动能指标)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}